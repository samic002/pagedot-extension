{
  "manifest_version": 3,
  "name": "PageDot",
  "version": "0.1.0",
  "description": "A beautiful floating page assistant shell for every website.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ]
}
